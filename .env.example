# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — HealthAI Coach Admin
# Copier ce fichier en .env.local et remplir les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── next-auth (Auth.js v5) ────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
AUTH_SECRET=remplacer-par-une-chaine-aleatoire-32-chars

# URL publique du frontend (utilisée par next-auth pour les callbacks)
AUTH_URL=http://localhost:3000

# ── ZITADEL (provider OIDC) ───────────────────────────────────────────────────
# URL de ton instance ZITADEL (sans slash final)
ZITADEL_ISSUER=https://your-instance.zitadel.cloud

# Application "Web" créée dans ZITADEL > Projets > <ton projet> > Applications
# Type : Web — Auth Method : Basic (pour client_secret)
# Redirect URI autorisée : http://localhost:3000/api/auth/callback/zitadel
ZITADEL_CLIENT_ID=remplacer-par-le-client-id
ZITADEL_CLIENT_SECRET=remplacer-par-le-client-secret

# ── NestJS API ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_NESTJS_URL=http://localhost:3001

# API Key — doit correspondre à API_KEY dans le .env du NestJS
NEXT_PUBLIC_API_KEY=remplacer-par-la-meme-valeur-que-dans-nestjs

# Client ID — doit correspondre à FRONTEND_CLIENT_ID dans le .env du NestJS
NEXT_PUBLIC_CLIENT_ID=healthai-admin-front

# ── FastAPI ETL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# ── Metabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_METABASE_URL=http://localhost:4000
METABASE_SECRET_KEY=

# ── Bascule mock / API réelle ─────────────────────────────────────────────────
# Passer à "false" pour utiliser l'API réelle
NEXT_PUBLIC_USE_MOCK=true

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=development
