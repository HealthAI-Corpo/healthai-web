# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — HealthAI Coach Frontend
# Copier ce fichier en .env.local et remplir les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# Passer à "false" pour passer en mode API réelle (défaut : mock)
NEXT_PUBLIC_USE_MOCK=true

# ── NestJS API (port 3001 par défaut) ────────────────────────────────────────
NEXT_PUBLIC_NESTJS_URL=http://localhost:3001

# API Key — doit correspondre exactement à API_KEY dans le .env du NestJS
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_API_KEY=remplacer-par-la-meme-valeur-que-dans-nestjs

# Client ID — doit correspondre à FRONTEND_CLIENT_ID dans le .env du NestJS
# Valeur libre, min 8 caractères ex: "healthai-admin-front"
NEXT_PUBLIC_CLIENT_ID=healthai-admin-front

# ── FastAPI ETL (port 8000 par défaut) ───────────────────────────────────────
# Pas d'auth pour l'instant côté ETL
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# ── Metabase (port 4000 par défaut) ──────────────────────────────────────────
# URL de ton instance Metabase locale ou distante
NEXT_PUBLIC_METABASE_URL=http://localhost:4000

# Clé d'embed — Metabase > Paramètres > Embedding > Clé secrète d'intégration
# Laisser vide si tu n'utilises pas les embeds signés
METABASE_SECRET_KEY=

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=development
